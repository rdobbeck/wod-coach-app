# Database (Supabase)
# Pooled connection for app runtime, direct for migrations
POSTGRES_PRISMA_URL="postgresql://postgres:password@host.pooler.supabase.com:6543/postgres?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://postgres:password@host.supabase.co:5432/postgres"

# Supabase service role (server-side only — never ship to client)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# OpenTabs (local) — used by scripts/sync-coachrx.ts
# OPENTABS_AUTH_TOKEN auto-loads from ~/.opentabs/config.json if unset
OPENTABS_BASE_URL="http://127.0.0.1:9515"
OPENTABS_AUTH_TOKEN=""

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Wearables APIs
APPLE_HEALTH_CLIENT_ID=""
WHOOP_CLIENT_ID=""
WHOOP_CLIENT_SECRET=""
OURA_CLIENT_ID=""
OURA_CLIENT_SECRET=""
GARMIN_CONSUMER_KEY=""
GARMIN_CONSUMER_SECRET=""
FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""

# AI (OpenAI or Anthropic)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
